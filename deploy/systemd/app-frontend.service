[Unit]
Description=Frontend service
After=network.target

[Service]
User=app
Group=app
Environment=NODE_ENV=production
EnvironmentFile=-/etc/app-stack/frontend.env
WorkingDirectory=/opt/app-stack/frontend/current
ExecStart=/usr/bin/node /opt/app-stack/frontend/current/server.js
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
